---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, cover, coverAlt, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/posts/${post.slug}/`} class="group block">
  <article>
    {cover && (
      <div class="overflow-hidden rounded-sm mb-5 aspect-video bg-brand-dusk/20">
        <Image
          src={cover}
          alt={coverAlt ?? title}
          width={640}
          height={360}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      </div>
    )}
    <div class="flex flex-wrap gap-1.5 mb-3">
      {tags.map((tag) => <span class="term-tag">{tag}</span>)}
    </div>
    <h2 class="font-sans text-2xl md:text-3xl font-bold tracking-tightest text-brand-paper leading-tight group-hover:text-brand-glow transition-colors mb-3">
      {title}
    </h2>
    <p class="text-brand-fog/70 text-base font-sans leading-relaxed mb-4">
      {description}
    </p>
    <time class="font-mono text-sm text-brand-fog/50">{formattedDate}</time>
  </article>
</a>
