---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'posts'>;
}

const { article } = Astro.props;
const { title, description, pubDate, cover, coverAlt, tags } = article.data;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
---

<li>
  <a href={`/posts/${article.slug}/`} class="group block">
    <article class="flex gap-6 py-8 hairline hover:bg-brand-fog/5 transition-colors px-3 -mx-3 rounded-sm">
      {cover && (
        <div class="shrink-0 w-28 h-28 sm:w-36 sm:h-36 overflow-hidden rounded-sm bg-brand-dusk/20">
          <Image
            src={cover}
            alt={coverAlt ?? title}
            width={112}
            height={112}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
        </div>
      )}
      <div class="flex-1 min-w-0">
        <time class="font-mono text-sm text-brand-fog/50 tracking-wide">{formattedDate}</time>
        <h2 class="font-sans text-lg md:text-xl font-semibold text-brand-paper mt-1.5 leading-snug tracking-tight group-hover:text-brand-glow transition-colors line-clamp-2">
          {title}
        </h2>
        <p class="text-brand-fog/70 text-base mt-2 line-clamp-2 font-sans leading-relaxed">
          {description}
        </p>
        {tags.length > 0 && (
          <ul class="flex flex-wrap gap-1.5 mt-3">
            {tags.map((tag) => (
              <li class="term-tag">{tag}</li>
            ))}
          </ul>
        )}
      </div>
    </article>
  </a>
</li>
