---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, description, pubDate, cover, coverAlt, tags } = article.data;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
---

<li>
  <a href={`/articles/${article.slug}/`} class="group block">
    <article class="flex gap-5 py-6 hairline hover:bg-brand-fog/5 transition-colors px-2 -mx-2 rounded-sm">
      {cover && (
        <div class="shrink-0 w-24 h-24 sm:w-28 sm:h-28 overflow-hidden rounded-sm bg-brand-dusk/20">
          <Image
            src={cover}
            alt={coverAlt ?? title}
            width={112}
            height={112}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
        </div>
      )}
      <div class="flex-1 min-w-0">
        <time class="font-mono text-xs text-brand-fog/50 tracking-wide">{formattedDate}</time>
        <h2 class="font-sans text-base md:text-lg font-semibold text-brand-paper mt-1 leading-snug tracking-tight group-hover:text-brand-glow transition-colors line-clamp-2">
          {title}
        </h2>
        <p class="text-brand-fog/70 text-sm mt-1.5 line-clamp-2 font-sans leading-relaxed">
          {description}
        </p>
        {tags.length > 0 && (
          <ul class="flex flex-wrap gap-1.5 mt-2.5">
            {tags.map((tag) => (
              <li class="text-[10px] uppercase tracking-widest font-mono text-brand-fog/50 border border-brand-fog/20 px-1.5 py-0.5 rounded-sm">
                {tag}
              </li>
            ))}
          </ul>
        )}
      </div>
    </article>
  </a>
</li>
