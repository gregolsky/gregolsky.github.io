---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';

const articles = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Grzegorz Lachowski" description="Articles on software development, tools, and things I find interesting.">
  <Header />
  <main class="flex-1">
    <div class="max-w-3xl mx-auto px-6 md:px-10 py-10 md:py-14">
      <h2 class="font-mono text-sm text-brand-fog/60 mb-8 term-prompt">ls posts/</h2>
      <ul class="divide-y divide-brand-fog/10">
        {articles.map((article) => <ArticleCard article={article} />)}
      </ul>
    </div>
  </main>
  <Footer />
</BaseLayout>
