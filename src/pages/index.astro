---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FeaturedPost from '../components/FeaturedPost.astro';
import SidebarPost from '../components/SidebarPost.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [latest, ...older] = posts;
---

<BaseLayout title="Grzegorz Lachowski" description="Posts on software development, tools, and things I find interesting.">
  <Header />
  <main class="flex-1">
    <div class="max-w-5xl mx-auto px-6 md:px-10 py-10 md:py-14">
      <h2 class="font-mono text-sm text-brand-fog/60 mb-8 term-prompt">ls posts/</h2>

      <div class="grid grid-cols-1 md:grid-cols-[1fr_300px] gap-10 md:gap-14 items-start">

        <!-- Featured latest post -->
        {latest && <FeaturedPost post={latest} />}

        <!-- Sidebar: older posts -->
        {older.length > 0 && (
          <aside>
            <p class="font-mono text-xs text-brand-fog/40 uppercase tracking-widest mb-2 term-prompt">older</p>
            <ul class="divide-y divide-brand-fog/10">
              {older.map((post) => <SidebarPost post={post} />)}
            </ul>
          </aside>
        )}

      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
