---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SocialIcons from '../components/SocialIcons.astro';
import { Image } from 'astro:assets';
import avatarSrc from '../assets/avatar.jpg';
---

<BaseLayout title="About" description="About Grzegorz Lachowski — software developer, team lead at RavenDB, based in Toruń, Poland.">
  <Header compact />
  <main class="flex-1">
    <div class="max-w-3xl mx-auto px-6 md:px-10 py-10 md:py-14">

      <!-- Identity -->
      <div class="flex items-center gap-5 mb-8">
        <Image
          src={avatarSrc}
          alt="Grzegorz Lachowski"
          width={80}
          height={80}
          class="w-16 h-16 md:w-20 md:h-20 rounded-full ring-1 ring-brand-fog/40 shrink-0 object-cover"
        />
        <div>
          <h1 class="font-sans text-2xl md:text-3xl font-bold tracking-tightest text-brand-paper">Grzegorz Lachowski</h1>
          <p class="text-brand-fog/60 text-sm font-mono mt-0.5">Toruń, Poland · @gregolsky</p>
        </div>
      </div>

      <SocialIcons class="mb-10" />

      <!-- Bio (from Instagram) -->
      <section class="mb-10">
        <ul class="space-y-1 text-brand-fog font-sans text-base leading-relaxed">
          <li>Programmer, tech geek 👨‍💻💾🖱️💿</li>
          <li>Insects and arachnids lover 🐝🦗🦟🐞🕷️🐛</li>
          <li>Sci-fi addict 🚀🌠🌌🤖</li>
          <li>Music lover 🎸🎧🥁🎹</li>
          <li>Father of 4 👨‍👩‍👧‍👦</li>
        </ul>
      </section>

      <div class="hairline mb-10"></div>

      <!-- Professional -->
      <h2 class="font-mono text-sm text-brand-fog/60 mb-6 term-prompt">whoami</h2>
      <section class="prose prose-invert prose-stone max-w-none">
        <p>
          Over 15 years in software development allowed me to explore sometimes very different roles, tech stacks and tooling.
          My heart has always been closer to the backend than the frontend.
          I would choose working with the cloud over low-level system programming.
          The command line rather than pretty user interfaces.
        </p>
        <p>
          I have been orbiting around the Microsoft tech stack including .NET, but not exclusively —
          building automations and pipelines to make life easier, falling in love with Linux,
          exploring the open-source world, enjoying scripting in Bash, Node.js, Python or else.
          Nowadays leading a team of ambitious people at <a href="https://ravendb.net" target="_blank" rel="noopener noreferrer">RavenDB</a>,
          enabling customers to persist and shape their data as they see fit.
        </p>
        <p>
          Alumnus of Nicolaus Copernicus University (UMK) in Toruń, Faculty of Mathematics and Computer Science, 2006–2011.
        </p>
      </section>

    </div>
  </main>
  <Footer />
</BaseLayout>
