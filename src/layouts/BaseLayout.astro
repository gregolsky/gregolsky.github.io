---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  articleDate?: Date;
  articleUpdatedDate?: Date;
}

const {
  title,
  description = 'Software developer, team lead at RavenDB. Writing about code, tools, and things I find interesting.',
  image = '/images/og.png',
  articleDate,
  articleUpdatedDate,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = 'Grzegorz Lachowski';
const siteURL = Astro.site!.toString();
const ogImageURL = new URL(image, Astro.site).toString();

const isArticle = Boolean(articleDate);
const isHomepage = Astro.url.pathname === '/';
const isAbout = Astro.url.pathname === '/about' || Astro.url.pathname === '/about/';

const jsonLd = isArticle
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      image: ogImageURL,
      datePublished: articleDate!.toISOString(),
      ...(articleUpdatedDate ? { dateModified: articleUpdatedDate.toISOString() } : {}),
      author: {
        '@type': 'Person',
        name: siteName,
        url: siteURL,
      },
      publisher: {
        '@type': 'Person',
        name: siteName,
        url: siteURL,
      },
      url: canonicalURL.toString(),
    }
  : isAbout
  ? {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: siteName,
      url: siteURL,
      jobTitle: 'Software Developer',
      worksFor: { '@type': 'Organization', name: 'RavenDB' },
      sameAs: [
        'https://github.com/gregolsky',
        'https://www.linkedin.com/in/gregolsky/',
      ],
    }
  : isHomepage
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: siteName,
      url: siteURL,
      description,
      author: {
        '@type': 'Person',
        name: siteName,
      },
    }
  : null;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title === siteName ? title : `${title} — ${siteName}`}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    {articleDate && <meta property="article:published_time" content={articleDate.toISOString()} />}
    {articleUpdatedDate && <meta property="article:modified_time" content={articleUpdatedDate.toISOString()} />}

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Structured data -->
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-N7GDB1FP14"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-N7GDB1FP14', {
        cookie_domain: 'gregolsky.github.io',
        cookie_flags: 'SameSite=None;Secure'
      });
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>
