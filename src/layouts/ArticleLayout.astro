---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, description, pubDate, cover, coverAlt, tags } = article.data;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} articleDate={pubDate}>
  <Header compact />
  <main class="flex-1">
    <div class="max-w-3xl mx-auto px-6 md:px-10 py-10 md:py-14">
      <header class="mb-8">
        <div class="flex flex-wrap gap-1.5 mb-3">
          {tags.map((tag) => (
            <span class="text-[10px] uppercase tracking-widest font-mono text-brand-fog/50 border border-brand-fog/20 px-1.5 py-0.5 rounded-sm">
              {tag}
            </span>
          ))}
        </div>
        <h1 class="font-sans text-2xl md:text-4xl font-bold tracking-tightest text-brand-paper leading-tight mb-3">
          {title}
        </h1>
        <time class="font-mono text-xs text-brand-fog/50 tracking-wide">{formattedDate}</time>
      </header>

      {cover && (
        <div class="mb-8 overflow-hidden rounded-sm">
          <Image
            src={cover}
            alt={coverAlt ?? title}
            width={768}
            height={432}
            class="w-full object-cover"
          />
        </div>
      )}

      <div class="prose prose-invert prose-stone max-w-none">
        <slot />
      </div>

      <div class="mt-10 pt-6 hairline">
        <a href="/" class="font-mono text-xs text-brand-fog/50 hover:text-brand-glow transition-colors tracking-wide uppercase">
          ← All articles
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
